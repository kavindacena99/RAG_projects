DJANGO_SECRET_KEY=replace-with-a-real-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=true

# MySQL is required for all Django relational data.
# SQLite is unsupported and there is no fallback path.
MYSQL_DATABASE=rag_app
MYSQL_USER=rag_user
MYSQL_PASSWORD=replace-with-a-real-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# ChromaDB remains the persistent vector store.
CHROMA_COLLECTION_NAME=study_notes
CHROMA_PERSIST_DIR=./chroma_db

LLM_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-4.1-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

RAG_TOP_K=6
RAG_RETRIEVE_K=8
RAG_FINAL_TOP_N=3
RAG_ENABLE_RERANKING=true
RAG_LOG_LEVEL=INFO
RAG_LLM_LOG_LEVEL=INFO
CHAT_MAX_HISTORY_PAIRS=3
RAG_CHAT_MAX_RETRIEVED_CHUNKS=4
LLM_MAX_OUTPUT_TOKENS=512
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=604800
